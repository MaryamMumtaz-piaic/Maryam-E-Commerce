# ---- Database (Neon Postgres) ----
# Get this from your Neon dashboard. Example:
# postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ---- Auth.js / NextAuth v5 ----
# Generate with: npx auth secret  (or any random 32+ char string)
AUTH_SECRET=
# Base URL of the app (no trailing slash)
AUTH_URL=http://localhost:3000

# Comma-separated admin emails. Accounts with these emails get the ADMIN role.
ADMIN_EMAILS=m.samiwaseem1234@gmail.com

# ---- Stripe (test mode) ----
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- OpenAI (chatbot) ----
OPENAI_API_KEY=

# Public site URL for Stripe redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000
